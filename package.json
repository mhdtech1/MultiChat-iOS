{
  "name": "multichat-ios-workspace",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "ios": "pnpm --filter @multichat/ios ios",
    "dev:ios": "pnpm --filter @multichat/ios ios",
    "build:chat-core": "pnpm --filter @multichat/chat-core build"
  }
}
